{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "brand": {
    "name": "Bobby",
    "tagline": "Your personal project builder"
  },
  "color": {
    "brand": {
      "yellow":  { "value": "#facc15", "type": "color", "description": "Primary CTA. Pair with #000000 text." },
      "surface": { "value": "#17171a", "type": "color", "description": "Elevated surfaces — nav, cards." },
      "bg":      { "value": "#0d0d0f", "type": "color", "description": "Page background (dark default)." }
    },
    "tile": {
      "green":  { "value": "#1db954", "type": "color" },
      "orange": { "value": "#f5a623", "type": "color" },
      "blue":   { "value": "#2563eb", "type": "color" },
      "red":    { "value": "#f04e30", "type": "color" },
      "purple": { "value": "#7c3aed", "type": "color" }
    },
    "soft": {
      "blue":    { "value": "#a2d2ff", "type": "color" },
      "blue-2":  { "value": "#bde0fe", "type": "color" },
      "pink":    { "value": "#ffafcc", "type": "color" },
      "pink-2":  { "value": "#ffc8dd", "type": "color" },
      "purple":  { "value": "#cdb4db", "type": "color" }
    },
    "neutral": {
      "000": { "value": "#ffffff", "type": "color" },
      "050": { "value": "#fcfcfc", "type": "color" },
      "100": { "value": "#f9f9f9", "type": "color" },
      "200": { "value": "#e5e7eb", "type": "color" },
      "300": { "value": "#d1d5db", "type": "color" },
      "400": { "value": "#9ca3af", "type": "color" },
      "500": { "value": "#6b7280", "type": "color" },
      "600": { "value": "#4b5563", "type": "color" },
      "800": { "value": "#1f2937", "type": "color" },
      "900": { "value": "#17171a", "type": "color" },
      "950": { "value": "#0d0d0f", "type": "color" }
    },
    "semantic": {
      "text": {
        "primary":   { "light": "#1f2937", "dark": "#ffffff" },
        "secondary": { "light": "#6b7280", "dark": "#9ca3af" },
        "link":      { "light": "#a16207", "dark": "#facc15" },
        "code":      { "light": "#be185d", "dark": "#f9a8d4" }
      },
      "border": {
        "default":   { "light": "#e5e7eb", "dark": "rgba(255,255,255,0.08)" },
        "strong":    { "light": "#d1d5db", "dark": "rgba(255,255,255,0.12)" }
      },
      "overlay": {
        "hover":     { "light": "rgba(0,0,0,0.06)", "dark": "rgba(255,255,255,0.06)" },
        "selection": { "value": "rgba(99,102,241,0.25)" }
      }
    }
  },
  "font": {
    "family": {
      "sans": { "value": "Nunito, system-ui, -apple-system, sans-serif", "type": "fontFamily" },
      "mono": { "value": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace", "type": "fontFamily" }
    },
    "size": {
      "xs":   { "value": "0.75rem" },
      "sm":   { "value": "0.875rem" },
      "base": { "value": "1rem" },
      "lg":   { "value": "1.125rem" },
      "xl":   { "value": "1.25rem" },
      "2xl":  { "value": "1.5rem" },
      "3xl":  { "value": "1.875rem" },
      "hero": { "value": "clamp(2rem, 4vw, 2.75rem)" }
    },
    "weight": {
      "regular":   { "value": 400 },
      "medium":    { "value": 500 },
      "semibold":  { "value": 600 },
      "bold":      { "value": 700 },
      "extrabold": { "value": 800 }
    },
    "lineHeight": {
      "tight": { "value": 1.1 },
      "ui":    { "value": 1.3 },
      "prose": { "value": 1.7 }
    },
    "tracking": {
      "h1":     { "value": "-0.02em" },
      "h2":     { "value": "-0.01em" },
      "label":  { "value": "0.18em" }
    }
  },
  "spacing": {
    "0.5": { "value": "2px" },
    "1":   { "value": "4px" },
    "2":   { "value": "8px" },
    "3":   { "value": "12px" },
    "4":   { "value": "16px" },
    "5":   { "value": "20px" },
    "6":   { "value": "24px" },
    "8":   { "value": "32px" },
    "10":  { "value": "40px" },
    "12":  { "value": "48px" },
    "14":  { "value": "56px" },
    "16":  { "value": "64px" }
  },
  "radius": {
    "sm":   { "value": "8px" },
    "md":   { "value": "12px" },
    "lg":   { "value": "16px" },
    "xl":   { "value": "24px" },
    "full": { "value": "9999px" }
  },
  "shadow": {
    "nav":        { "value": "0 20px 25px -5px rgba(0,0,0,0.30)" },
    "nav-mobile": { "value": "0 20px 25px -5px rgba(0,0,0,0.40)" },
    "card":       { "value": "0 10px 15px -3px rgba(0,0,0,0.10)" },
    "tile":       { "value": "0 8px 24px 2px {tile-color}55" }
  },
  "breakpoint": {
    "sm":  { "value": "640px" },
    "md":  { "value": "768px" },
    "lg":  { "value": "1024px" },
    "xl":  { "value": "1280px" },
    "2xl": { "value": "1536px" }
  },
  "motion": {
    "ease": {
      "natural":   { "value": "cubic-bezier(0.22, 0.10, 0.35, 1)" },
      "overshoot": { "value": "cubic-bezier(0.22, 1.00, 0.36, 1)" }
    },
    "duration": {
      "micro": { "value": "200ms" },
      "short": { "value": "300ms" },
      "medium":{ "value": "500ms" },
      "long":  { "value": "700ms" }
    },
    "spring": {
      "default": { "stiffness": 500, "damping": 40 }
    }
  },
  "gradient": {
    "hero-text": {
      "value": "linear-gradient(135deg, #6366f1 0%, #8b5cf6 55%, #a78bfa 100%)"
    },
    "yellow-glow": {
      "value": "radial-gradient(circle, rgba(250,204,21,0.25) 0%, rgba(250,204,21,0.11) 25%, rgba(250,204,21,0.04) 50%, transparent 70%)"
    },
    "indigo-glow": {
      "value": "radial-gradient(circle, rgba(99,102,241,0.14) 0%, rgba(124,77,255,0.05) 45%, transparent 70%)"
    }
  }
}
