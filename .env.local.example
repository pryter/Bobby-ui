NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# REST API base URL
NEXT_PUBLIC_SERVICE_URL=http://localhost:4244

# WebSocket server URL (optional — defaults to SERVICE_URL with http→ws)
# The WS server runs on a separate port from the REST API.
# NEXT_PUBLIC_WS_URL=ws://localhost:4245

# Bobby Tracker base URL — used by the project Integrations page to
# enable / open the matching tracker project. Leave unset to hide the
# integration card.
# NEXT_PUBLIC_TRACKER_URL=https://tracker.example.com

# ── SSO (portal acts as identity provider for Component Zoo) ──────────────
# Signs the one-time authorization `code` (HS256 JWT). Any long random string.
SSO_SIGNING_SECRET=replace-with-a-long-random-string
# Shared secret Zoo presents at POST /api/sso/token (back-channel exchange).
ZOO_SSO_CLIENT_SECRET=replace-with-a-long-random-string
# Comma-separated allowlist of permitted Zoo callback URLs (exact match, no open redirect).
ZOO_SSO_REDIRECT_URIS=https://zoo.bobby.host/auth/callback,http://localhost:8787/auth/callback
