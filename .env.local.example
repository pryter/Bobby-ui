NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# REST API base URL
NEXT_PUBLIC_SERVICE_URL=http://localhost:4244

# WebSocket server URL (optional — defaults to SERVICE_URL with http→ws)
# The WS server runs on a separate port from the REST API.
# NEXT_PUBLIC_WS_URL=ws://localhost:4245
